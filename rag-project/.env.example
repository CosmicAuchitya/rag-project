# Copy this file to `.env` and replace the placeholder values.

# Interview/demo switch:
# `false` = fully local
# `true` = OpenAI embeddings + OpenAI answer generation
USE_OPENAI=false

# Put your OpenAI API key here when testing API mode.
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional if you use a compatible local server like LM Studio or Ollama gateway.
OPENAI_BASE_URL=

# Default document-RAG providers
EMBEDDING_PROVIDER=sentence_transformers
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LLM_PROVIDER=extractive
LLM_MODEL=gpt-4o-mini

# Video-RAG providers
VIDEO_EMBEDDING_PROVIDER=sentence_transformers
VIDEO_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VIDEO_LLM_PROVIDER=huggingface_local
VIDEO_LLM_MODEL=google/flan-t5-small

# OpenAI-mode recommendation for video/demo
# VIDEO_EMBEDDING_PROVIDER=openai
# VIDEO_EMBEDDING_MODEL=text-embedding-3-small
# VIDEO_LLM_PROVIDER=openai
# VIDEO_LLM_MODEL=gpt-4o-mini
